ContentLoader="*res://core/content_loader.gd"
SaveSystem="*res://core/save_system.gd"
ModLoader="*res://core/mod_loader.gd"
RunState="*res://core/run_state.gd"
WaveSpawner="*res://core/wave_spawner.gd"
PlayerMutations="*res://core/player_mutations.gd"
SfxBus="*res://core/audio/sfx_bus.gd"
MetaProgression="*res://core/meta_progression.gd"

