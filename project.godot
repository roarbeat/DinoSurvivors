; Godot-Projekt-Datei. Wird von Godot 4.x verwaltet.
; Manuelle Änderungen sind erlaubt, werden aber beim nächsten Editor-Save
; ggf. neu sortiert.

config_version=5

[application]

config/name="DinoRogue"
config/description="Roguelike-Survivor-likes mit Mutationssystem."
config/version="0.0.1"
config/features=PackedStringArray("4.3", "GL Compatibility")
run/main_scene="res://core/run_scene/run.tscn"
config/icon="res://icon.svg"

[autoload]

; Reihenfolge zählt — siehe ARCHITECTURE.md, Boot-Sequence.

; ADR 0001 — globaler Event-Hub. MUSS erster sein.
EventBus="*res://core/event_bus.gd"

; ADR 0003 — type-indizierte Content-Registry. NACH EventBus,
; weil discover_all() content_loaded.emit aufruft.
ContentLoader="*res://core/content_loader.gd"

; ADR 0002 — JSON-Save mit Schema-Migration. NACH ContentLoader,
; weil Save-Ref-Validation auf ContentLoader.has_item() trifft.
SaveSystem="*res://core/save_system.gd"
; ADR 0005 — Mod-Manifest-Parser. NACH ContentLoader und SaveSystem,
; weil ein Mod-Reload alle drei brauchen kann.
ModLoader="*res://core/mod_loader.gd"
; ADR 0006 — Run-State-Maschine. NACH ContentLoader (referenziert DinoDef).
RunState="*res://core/run_state.gd"
; ADR 0006 — Wave-Lifecycle. NACH RunState (subscribet run_started).
WaveSpawner="*res://core/wave_spawner.gd"
; ADR 0015 — Mutation-Aggregator. NACH ContentLoader (referenziert MutationDef)
; und EventBus (subscribt run_started, emittet mutations_changed).
PlayerMutations="*res://core/player_mutations.gd"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"

[internationalization]

; Lokalisierung von Tag 1 (Prinzip 4). po-Files vom localization-coordinator.
locale/translations=PackedStringArray("res://locale/de.po", "res://locale/en.po")
locale/fallback="en"

