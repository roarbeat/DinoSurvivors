# --- Mutations ---

msgid "mutation.triceratops_horns.name"
msgstr "Triceratops Horns"

msgid "mutation.triceratops_horns.tooltip"
msgstr "Three points for three problems. Which one first? (+15% damage, +10% melee range)"

msgid "mutation.spinosaur_sail.name"
msgstr "Spinosaurus Sail"

msgid "mutation.spinosaur_sail.tooltip"
msgstr "Solar show-off mode engaged. (+10% crit chance, +50% crit damage)"

msgid "mutation.ankylosaur_plates.name"
msgstr "Ankylosaurus Plates"

msgid "mutation.ankylosaur_plates.tooltip"
msgstr "Heavy like a vault, less inviting. (+20% armor, +15% max HP)"

msgid "mutation.velociraptor_dash.name"
msgstr "Velociraptor Dash"

msgid "mutation.velociraptor_dash.tooltip"
msgstr "Faster than thought. Faster than prey. (+20% speed, +10% pickup radius)"

msgid "mutation.t_rex_jaw.name"
msgstr "T-Rex Jaw"

msgid "mutation.t_rex_jaw.tooltip"
msgstr "Tiny arms, mighty bite. (+25% damage, +10% crit damage)"

msgid "mutation.stegosaurus_thagomizer.name"
msgstr "Stegosaurus Thagomizer"

msgid "mutation.stegosaurus_thagomizer.tooltip"
msgstr "Four spikes, one message. You are the message. (+15% damage, +5% crit chance)"

msgid "mutation.pterodactyl_glide.name"
msgstr "Pterodactyl Glide"

msgid "mutation.pterodactyl_glide.tooltip"
msgstr "Those who fly are bitten less often. (+25% speed, +15% pickup radius)"

